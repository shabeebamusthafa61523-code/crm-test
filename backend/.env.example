# =========================================================================
# KOD.BRAND Command Center CRM — STANDALONE BACKEND ENVIRONMENT VARIABLES
# =========================================================================

# --- Server Core Settings ---
PORT=5000
NODE_ENV=development

# --- Security & CORS Origins Whitelist ---
# Comma-separated domains whitelist allowed to invoke this standalone backend REST API
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database Relational Pool (PostgreSQL) ---
MONGO_URI=mongodb+srv://shabeeba:9995982324@cluster0.i23tzbf.mongodb.net/crm?appName=Cluster0

# --- Redis In-Memory Session Cache (IORedis connection string) ---
# REDIS_URL="redis://:redis_password@localhost:6379/0"

# --- Asymmetric Signature Verification (RS256 JWT Keys) ---
# Paste your 2048-bit base64-encoded PEM private and public keys.
# Development Fallback: If left blank or public/private.key files are absent from disk,
# the system programmatically spawns crypto keypairs and persists keys on start.
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# --- Unified Corporate Mailer (SMTP Credentials) ---
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_username_here"
SMTP_PASS="smtp_password_here"
SMTP_FROM="KOD.BRAND Command HQ <no-reply@kod.brand>"

# --- WhatsApp Cloud API Settings (Official Meta Cloud API Developer account) ---
# Development Fallback: If left blank, the WhatsApp client engages a mock console logger fallback automatically.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""

# --- Production SSL Configuration (Optional local HTTPS handshakes) ---
# SSL_CERT_PATH=""
# SSL_KEY_PATH=""
